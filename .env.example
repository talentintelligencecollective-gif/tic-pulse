# Copy to .env (never commit .env). Vite exposes only VITE_* to the browser.

# --- Client (Vite / React) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Netlify Functions (set in Netlify UI or netlify.toml [build.environment]) ---
# SUPABASE_URL is optional; functions accept VITE_SUPABASE_URL as fallback.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

YOUTUBE_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional tuning ---
# GDELT_RSS_PAIR_COUNT=3
# GDELT_INGEST_CAP=15
# GDELT_SUMMARISE_BATCH=5
# PODCAST_RSS_ITEM_CAP=40
